---
const socials = [
    { label: "GitHub", url: "https://github.com/AssahBismarkabah" },
    { label: "LinkedIn", url: "https://www.linkedin.com/in/assah-bismark-608a6a251/" },
    { label: "Medium", url: "https://medium.com/@assahbismarkabah" },
    { label: "X", url: "https://x.com/Assah_Bismark" },
    { label: "Instagram", url: "https://www.instagram.com/assah_bismark/" },
    { label: "Email", url: "mailto:abahbismarkassah@gmail.com" },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand">Assah Bismark</a>
    <nav class="header-nav">
      <a href="/blog" class="nav-link">Archive</a>
      <a href="/categories" class="nav-link">Categories</a>
      {socials.map((social) => (
        <a href={social.url} class="nav-link" target="_blank" rel="noopener noreferrer">{social.label}</a>
      ))}
    </nav>
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
      <span class="bar"></span>
    </button>
  </div>
</header>

<!-- Full-screen mobile menu overlay (outside header, appended to body) -->
<div class="mobile-overlay" id="mobile-overlay">
  <div class="mobile-overlay-header">
    <a href="/" class="brand">Assah Bismark</a>
    <button class="mobile-close" id="mobile-close" aria-label="Close menu">
      <span class="close-bar"></span>
    </button>
  </div>
  <nav class="mobile-nav">
    <a href="/blog" class="mobile-link">Archive</a>
    <a href="/categories" class="mobile-link">Categories</a>
    {socials.map((social) => (
      <a href={social.url} class="mobile-link" target="_blank" rel="noopener noreferrer">{social.label}</a>
    ))}
  </nav>
</div>

<style>
  .site-header {
    position: absolute;
    width: 100%;
    padding: 43px 0 35px;
    z-index: 10;
  }
  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 60px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .brand {
    font-size: 22px;
    font-weight: 700;
    color: #db0042;
    text-decoration: none;
    line-height: 22px;
    white-space: nowrap;
  }
  .brand:hover { color: #ff1a5e; }
  .header-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: baseline;
  }
  .nav-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 17px;
    font-weight: 500;
    line-height: 22px;
    text-transform: capitalize;
    transition: color 0.2s ease;
    white-space: nowrap;
  }
  .nav-link:hover { color: #db0042; }

  /* Hamburger toggle — hidden on desktop */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    flex-shrink: 0;
  }
  .menu-toggle .bar,
  .menu-toggle .bar::before,
  .menu-toggle .bar::after {
    display: block;
    width: 18px;
    height: 2px;
    background: #ffffff;
    border-radius: 1px;
    transition: transform 0.2s ease;
  }
  .menu-toggle .bar {
    position: relative;
  }
  .menu-toggle .bar::before,
  .menu-toggle .bar::after {
    content: '';
    position: absolute;
  }
  .menu-toggle .bar::before { top: -6px; }
  .menu-toggle .bar::after { top: 6px; }

  /* Full-screen mobile overlay — hidden by default */
  .mobile-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #000000;
    z-index: 999;
    padding: 0;
    overflow: auto;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .mobile-overlay.open {
    display: block;
    opacity: 1;
  }

  /* Overlay header — brand + close, site background color */
  .mobile-overlay-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 25px;
    background: #1e1f21;
    border-bottom: 1px solid #333333;
  }

  /* X close button */
  .mobile-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    width: 20px;
    height: 20px;
    position: relative;
  }
  .mobile-close .close-bar {
    display: block;
    width: 18px;
    height: 2px;
    background: transparent;
    position: relative;
  }
  .mobile-close .close-bar::before,
  .mobile-close .close-bar::after {
    content: '';
    position: absolute;
    display: block;
    width: 18px;
    height: 2px;
    background: #ffffff;
    border-radius: 1px;
    top: 0;
  }
  .mobile-close .close-bar::before {
    transform: rotate(45deg);
  }
  .mobile-close .close-bar::after {
    transform: rotate(-45deg);
  }

  /* Mobile nav links */
  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 20px 25px;
  }
  .mobile-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 400;
    line-height: 30px;
    margin-bottom: 5px;
    transition: color 0.2s ease;
  }
  .mobile-link:hover { color: #db0042; }

  /* Responsive */
  @media (max-width: 960px) {
    .header-inner { padding: 0 30px; }
  }

  @media (max-width: 768px) {
    .site-header {
      position: relative;
      padding: 20px 0;
    }
    .header-inner {
      padding: 0 24px;
      align-items: center;
    }
    .header-nav { display: none; }
    .menu-toggle { display: block; }
  }

  @media (max-width: 480px) {
    .header-inner { padding: 0 16px; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('mobile-close');

  function openMenu() {
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('open')) {
      closeMenu();
    }
  });

  // Auto-close when resizing back to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768 && overlay?.classList.contains('open')) {
      closeMenu();
    }
  });
</script>
