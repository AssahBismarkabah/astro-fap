---
import Header from '../components/Header.astro';
import Giscus from '../components/Giscus.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
const { frontmatter } = Astro.props;

function formatDate(dateString) {
  if (!dateString) return '';
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC'
  });
}

const safeFrontmatter = {
  title: frontmatter?.title || '',
  author: frontmatter?.author || null,
  description: frontmatter?.description || null,
  date: frontmatter?.date || null
};
---
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{safeFrontmatter.title}</title>
    <meta name="description" content={safeFrontmatter.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <style>
      @font-face {
        font-family: 'Benton Sans';
        src: url('/fonts/BentonSans-Regular.ttf') format('truetype');
        font-weight: 400 500;
        font-style: normal;
      }
      @font-face {
        font-family: 'Benton Sans';
        src: url('/fonts/BentonSans Medium.woff') format('woff'),
             url('/fonts/BentonSans Medium.otf') format('opentype');
        font-weight: 600 700;
        font-style: normal;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        font-family: 'Benton Sans', 'Segoe UI', 'Helvetica Neue', Arial,
          'Liberation Sans', system-ui, sans-serif;
      }
      body {
        background: #1e1f21;
        color: #ffffff;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .post-section {
        padding: 0 0 100px;
      }
      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
      }

      .post-header {
        padding-top: 140px;
      }

      .post-meta {
        font-size: 18px;
        font-weight: 500;
        color: #ffffff;
        line-height: 28px;
        margin-bottom: 31px;
      }

      .post-title {
        font-size: 40px;
        font-weight: 700;
        color: #ffffff;
        line-height: 56px;
        margin-bottom: 18px;
      }

      .post-description {
        font-size: 18px;
        font-weight: 500;
        color: #ffffff;
        line-height: 29px;
        padding-bottom: 29px;
      }

      .post-header-divider {
        border: none;
        border-top: 1px solid #e5e5e5;
        margin: 0;
      }

      .prose {
        color: #eeeeee;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        margin-top: 31px;
      }
      .prose :global(p) {
        margin: 0 0 24px;
      }
      .prose :global(h1),
      .prose :global(h2),
      .prose :global(h3),
      .prose :global(h4),
      .prose :global(h5),
      .prose :global(h6) {
        color: #db0042;
        font-weight: 700;
        margin-top: 2em;
        margin-bottom: 0.7em;
        padding-bottom: 0.4em;
        border-bottom: 1px solid #333333;
        line-height: 1.3;
      }
      .prose :global(h1) { font-size: 32px; }
      .prose :global(h2) { font-size: 24px; }
      .prose :global(h3) { font-size: 20px; }
      .prose :global(strong) {
        font-weight: 600;
        color: #ffffff;
      }
      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: 24px;
        padding-left: 1.5em;
      }
      .prose :global(li) {
        margin-bottom: 8px;
      }
      .prose :global(code) {
        background: #2a2a2a;
        padding: 0.2em 0.4em;
        border-radius: 0.3em;
        font-size: 0.9em;
      }
      .prose :global(pre) {
        background: #18181b;
        padding: 1em;
        border-radius: 0.5em;
        overflow-x: auto;
        margin-bottom: 24px;
      }
      .prose :global(pre code) {
        background: none;
        padding: 0;
      }
      .prose :global(blockquote) {
        border-left: 4px solid #e5e5e5;
        margin: 0 0 24px;
        padding-left: 1em;
        color: #b2b2b2;
      }
      .prose :global(img) {
        max-width: 70%;
        width: auto;
        height: auto;
        border-radius: 0.5em;
        margin: 24px auto;
        display: block;
      }
      .prose :global(a) {
        color: #60a5fa;
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 0.2s ease;
      }
      .prose :global(a:hover) {
        color: #93c5fd;
      }
      .prose :global(p:empty),
      .prose :global(div:empty) {
        display: none;
      }
      .prose :global(h1:first-child) {
        display: none;
      }

      .site-footer {
        border-top: 1px solid #2d2f30;
      }
      .site-footer .container {
        padding-top: 2rem;
        padding-bottom: 2rem;
      }
      .copyright {
        color: #4b5563;
        font-size: 0.875rem;
      }

      @media (max-width: 960px) {
        .container { padding: 0 30px; }
      }
      @media (max-width: 768px) {
        .container { padding: 0 24px; }
        .post-header { padding-top: 40px; }
        .post-title { font-size: 28px; line-height: 38px; }
      }
      @media (max-width: 480px) {
        .container { padding: 0 16px; }
        .post-title { font-size: 24px; line-height: 34px; }
      }
    </style>
  </head>
  <body>
    <Header />

    <section class="post-section">
      <div class="container">
        <div class="post-header">
          <div class="post-meta">{formatDate(safeFrontmatter.date)}</div>
          <h1 class="post-title">{safeFrontmatter.title}</h1>
          {safeFrontmatter.description && (
            <div class="post-description">{safeFrontmatter.description}</div>
          )}
        </div>
        <hr class="post-header-divider" />
        <div class="prose">
          <slot />
        </div>
        <Giscus />
      </div>
    </section>

    <ScrollAnimations />

    <footer class="site-footer">
      <div class="container">
        <span class="copyright">&copy; 2026 Assah Bismark</span>
      </div>
    </footer>
  </body>
</html>
