---
import ThemeInit from '../components/ThemeInit.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const docs = await Astro.glob('../pages/docs/**/*.md');

// Get current page index for next/prev navigation
const currentPath = Astro.url.pathname;
const currentIndex = docs.findIndex(doc => doc.url === currentPath);
const prevDoc = currentIndex > 0 ? docs[currentIndex - 1] : null;
const nextDoc = currentIndex < docs.length - 1 ? docs[currentIndex + 1] : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Assah Bismark - Software Engineering Documentation" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <ThemeInit />
    <style>
      @font-face {
        font-family: 'Benton Sans';
        src: url('/fonts/BentonSans-Regular.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
      }
      @font-face {
        font-family: 'Benton Sans';
        src: url('/fonts/BentonSans-Medium.woff') format('woff'),
             url('/fonts/BentonSans-Medium.otf') format('opentype');
        font-weight: 500 600;
        font-style: normal;
      }
      @font-face {
        font-family: 'Benton Sans';
        src: url('/fonts/BentonSans-Bold.otf') format('opentype');
        font-weight: 700;
        font-style: normal;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center" style="background: var(--bg); color: var(--text);">
    <main class="flex flex-col items-center justify-center w-full min-h-screen">
      <div class="w-full max-w-3xl mx-auto px-8 py-12">
        <article class="prose dark:prose-invert max-w-none text-center">
          <slot />
        </article>
      </div>
    </main>
  </body>
</html>

<style is:global>
  html {
    font-family: 'Benton Sans', 'Segoe UI', 'Helvetica Neue', Arial, 'Liberation Sans', system-ui, sans-serif;
    background: var(--bg);
    transition: background 0.2s ease;
  }
</style>
