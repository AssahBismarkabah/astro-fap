---
import Header from '../components/Header.astro';

interface MarkdownInstance {
    frontmatter: any;
    rawContent: () => string;
    url?: string;
}

const postImports = import.meta.glob('./docs/blog/*.md', { eager: true }) as Record<string, MarkdownInstance>;
const posts = Object.entries(postImports).map(([path, mod]) => {
    let preview = '';
    if (mod.rawContent) {
        const rawText = mod.rawContent();
        const contentWithoutFrontmatter = rawText.replace(/^---[\s\S]*?---\n\n?/, '');
        const cleanText = contentWithoutFrontmatter
            .replace(/#{1,6}\s+/g, '')
            .replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1')
            .replace(/```[\s\S]*?```/g, '')
            .replace(/`[^`]+`/g, '')
            .replace(/\*\*([^\*]+)\*\*/g, '$1')
            .replace(/\*([^\*]+)\*/g, '$1')
            .replace(/\n+/g, ' ')
            .trim();
        preview = cleanText.substring(0, 300) + (cleanText.length > 300 ? '...' : '');
    } else if (mod.frontmatter?.description) {
        preview = mod.frontmatter.description;
    }
    return {
        url: path.replace('./docs/blog/', '/docs/blog/').replace('.md', ''),
        frontmatter: mod.frontmatter,
        preview,
    };
});
posts.sort((a, b) => (b.frontmatter.date || '').localeCompare(a.frontmatter.date || ''));

function formatDate(dateString: string): string {
    if (!dateString) return '';
    const date = new Date(dateString);
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        timeZone: 'UTC',
    });
}
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Assah Bismark</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <style>
            @font-face {
                font-family: "SF Pro";
                src: url("/fonts/SF-Pro.ttf") format("truetype");
                font-weight: 400;
                font-style: normal;
            }
            @font-face {
                font-family: "SF Pro";
                src: url("/fonts/SF-Pro-Display-Bold.otf") format("opentype");
                font-weight: 700;
                font-style: normal;
            }
            @font-face {
                font-family: "SF Pro";
                src: url("/fonts/SF-Pro-Italic.ttf") format("truetype");
                font-weight: 400;
                font-style: italic;
            }
            @font-face {
                font-family: "SF Pro";
                src: url("/fonts/SF-Pro-Text-Regular.otf") format("opentype");
                font-weight: 500;
                font-style: normal;
            }
            * { box-sizing: border-box; margin: 0; padding: 0; }
            html {
                font-family: "SF Pro", "SF Pro Display", "SF Pro Text", "San Francisco",
                    "Segoe UI", "Helvetica Neue", Arial, "Liberation Sans",
                    system-ui, sans-serif;
            }
            body {
                background: #1e1f21;
                color: #ffffff;
                font-size: 18px;
                font-weight: 500;
                line-height: 28px;
                min-height: 100vh;
            }

            .blog-section {
                padding: 177px 0 100px;
            }
            .container {
                max-width: 900px;
                margin: 0 auto;
                padding: 0 60px;
            }

            .post-entry {
                padding: 73px 0 0;
            }
            .post-entry:first-child {
                padding-top: 0;
            }

            .post-title-link {
                text-decoration: none;
                color: inherit;
            }
            .post-title {
                font-size: 22px;
                font-weight: 700;
                color: #ffffff;
                line-height: 28px;
                margin-bottom: 13px;
            }
            .post-title-link:hover .post-title {
                color: #db0042;
            }

            .post-description {
                font-size: 18px;
                font-weight: 500;
                color: #ffffff;
                line-height: 29px;
                margin-bottom: 11px;
            }

            .post-preview {
                font-size: 17px;
                font-weight: 500;
                color: #b2b2b2;
                line-height: 30.5px;
            }

            .post-more {
                font-size: 13px;
                font-weight: 500;
                color: #aaaaaa;
                text-decoration: none;
                line-height: 30.5px;
                display: inline;
                position: relative;
                transition: color 0.2s ease;
            }
            .post-more:hover {
                color: #ffffff;
            }
            .post-more-spacer {
                display: inline-block;
                width: 8px;
            }

            .post-entry.hidden-post {
                display: none;
            }

            .read-more-btn {
                display: inline-block;
                margin-top: 73px;
                font-size: 18px;
                font-weight: 600;
                line-height: 28px;
                color: #db0042;
                background: none;
                border: none;
                cursor: pointer;
                font-family: inherit;
                padding: 0;
                transition: color 0.2s ease;
            }
            .read-more-btn:hover {
                color: #ff1a5e;
            }
            .read-more-btn.hidden {
                display: none;
            }

            .post-meta {
                font-size: 18px;
                font-weight: 500;
                color: #ffffff;
                line-height: 28px;
            }

            .site-footer {
                border-top: 1px solid #2d2f30;
            }
            .site-footer .container {
                padding-top: 2rem;
                padding-bottom: 2rem;
            }
            .copyright {
                color: #4b5563;
                font-size: 0.875rem;
            }

            @media (max-width: 960px) {
                .container {
                    padding: 0 30px;
                }
            }
            @media (max-width: 768px) {
                .container {
                    padding: 0 24px;
                }
                .blog-section {
                    padding: 40px 0 60px;
                }
                .post-entry {
                    padding-top: 48px;
                }
                .post-title {
                    font-size: 20px;
                }
            }
            @media (max-width: 480px) {
                .container {
                    padding: 0 16px;
                }
                .blog-section {
                    padding: 32px 0 40px;
                }
                .post-entry {
                    padding-top: 36px;
                }
            }
        </style>
    </head>
    <body>
        <Header />

        <section class="blog-section">
            <div class="container">
                {posts.map((post, i) => (
                    <article class={`post-entry${i >= 5 ? ' hidden-post' : ''}`}>
                        <div class="post-meta">{formatDate(post.frontmatter.date)}</div>
                        <a href={post.url} class="post-title-link">
                            <h2 class="post-title">{post.frontmatter.title}</h2>
                        </a>
                        {post.frontmatter.description && (
                            <div class="post-description">{post.frontmatter.description}</div>
                        )}
                        <div class="post-preview">
                            {post.preview}<span class="post-more-spacer"></span><a href={post.url} class="post-more">More &rsaquo;</a>
                        </div>
                    </article>
                ))}
                {posts.length > 5 && (
                    <button class="read-more-btn" id="read-more-btn">Read More</button>
                )}
            </div>
        </section>

        <script>
            const btn = document.getElementById('read-more-btn');
            btn?.addEventListener('click', () => {
                document.querySelectorAll('.hidden-post').forEach(el => {
                    el.classList.remove('hidden-post');
                });
                btn.classList.add('hidden');
            });
        </script>

        <footer class="site-footer">
            <div class="container">
                <span class="copyright">&copy; 2026 Assah Bismark</span>
            </div>
        </footer>
    </body>
</html>
