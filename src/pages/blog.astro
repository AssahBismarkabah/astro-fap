---
import Header from '../components/Header.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';

interface MarkdownInstance {
  frontmatter: any;
  url?: string;
}

const postImports = import.meta.glob('./docs/blog/*.md', { eager: true }) as Record<string, MarkdownInstance>;
const posts = Object.entries(postImports).map(([path, mod]) => {
  const date = mod.frontmatter?.date || '';
  const year = date ? new Date(date).getUTCFullYear().toString() : 'Undated';
  return {
    url: path.replace('./docs/blog/', '/docs/blog/').replace('.md', ''),
    title: mod.frontmatter?.title || path.split('/').pop()?.replace('.md', '') || '',
    date,
    year,
  };
});
posts.sort((a, b) => (b.date || '').localeCompare(a.date || ''));

// Group by year
const years: Record<string, typeof posts> = {};
posts.forEach(post => {
  if (!years[post.year]) years[post.year] = [];
  years[post.year].push(post);
});
const sortedYears = Object.keys(years).sort((a, b) => b.localeCompare(a));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Archive | Assah Bismark</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <style>
      @font-face {
        font-family: "Benton Sans";
        src: url("/fonts/BentonSans-Regular.ttf") format("truetype");
        font-weight: 400;
        font-style: normal;
      }
      @font-face {
        font-family: "Benton Sans";
        src: url("/fonts/BentonSans Medium.woff") format("woff"),
             url("/fonts/BentonSans Medium.otf") format("opentype");
        font-weight: 500 600;
        font-style: normal;
      }
      @font-face {
        font-family: "Benton Sans";
        src: url("/fonts/BentonSans-Bold.otf") format("opentype");
        font-weight: 700;
        font-style: normal;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        font-family: "Benton Sans", "Segoe UI", "Helvetica Neue", Arial,
          "Liberation Sans", system-ui, sans-serif;
      }
      body {
        background: #1e1f21;
        color: #ffffff;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .archive-section {
        padding: 165px 0 100px;
      }
      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
      }

      .archive-title {
        font-size: 32px;
        font-weight: 700;
        color: #ffffff;
        line-height: 45px;
        margin: 0 0 23px;
      }

      .search-block {
        margin: 0 0 50px;
        position: relative;
      }
      .search-form {
        display: flex;
        position: relative;
        width: 100%;
        height: 31px;
      }
      .search-icon {
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 13px;
        height: 13px;
        opacity: 0.7;
        pointer-events: none;
      }
      .search-icon svg {
        width: 13px;
        height: 13px;
        fill: #4c4c4c;
      }
      .search-input {
        font-family: inherit;
        font-size: 15px;
        font-weight: 400;
        color: #ffffff;
        background: transparent;
        border: none;
        border-bottom: 1px solid #ffffff;
        border-radius: 0;
        width: 100%;
        height: 31px;
        padding: 0 0 0 21px;
        line-height: 22.5px;
        outline: none;
      }
      .search-input::placeholder {
        color: #999999;
      }

      .list-block {
        margin: 0 0 50px;
      }

      .block-title {
        font-size: 17px;
        font-weight: 700;
        color: #ffffff;
        line-height: 30px;
        margin: 0 0 15px;
        opacity: 0.4;
      }

      .year-title {
        font-size: 17px;
        font-weight: 700;
        color: #ffffff;
        line-height: 30px;
        margin: 0 0 15px;
        opacity: 0.4;
      }

      .link-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .link-list li {
        margin: 0 0 5px;
        list-style: none;
      }

      .post-link {
        font-size: 20px;
        font-weight: 700;
        color: #ffffff;
        line-height: 40px;
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .post-link:hover { color: #db0042; }

      .link-list li.hidden { display: none; }
      .list-block.hidden { display: none; }

      .site-footer { border-top: 1px solid #2d2f30; }
      .site-footer .container { padding-top: 2rem; padding-bottom: 2rem; }
      .copyright { color: #4b5563; font-size: 0.875rem; }

      @media (max-width: 960px) {
        .container { padding: 0 30px; }
      }
      @media (max-width: 768px) {
        .container { padding: 0 24px; }
        .archive-section { padding: 40px 0 60px; }
        .archive-title { font-size: 26px; line-height: 36px; }
        .post-link { font-size: 18px; line-height: 36px; }
      }
      @media (max-width: 480px) {
        .container { padding: 0 16px; }
        .archive-section { padding: 32px 0 40px; }
        .archive-title { font-size: 24px; }
        .post-link { font-size: 17px; line-height: 32px; }
      }
    </style>
  </head>
  <body>
    <Header />

    <section class="archive-section">
      <div class="container">
        <h1 class="archive-title">Archive</h1>

        <div class="search-block">
          <div class="search-form">
            <div class="search-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"/></svg>
            </div>
            <input type="search" class="search-input" id="archive-search" placeholder="Search..." autocomplete="off" />
          </div>
        </div>

        <div class="list-block" id="top-posts-block">
          <h2 class="block-title">Top Posts</h2>
          <ul class="link-list">
            {posts.slice(0, 5).map((post) => (
              <li>
                <a href={post.url} class="post-link">{post.title}</a>
              </li>
            ))}
          </ul>
        </div>

        {sortedYears.map((year) => (
          <div class="list-block year-section">
            <h2 class="year-title">{year}</h2>
            <ul class="link-list">
              {years[year].map((post) => (
                <li data-title={post.title.toLowerCase()}>
                  <a href={post.url} class="post-link">{post.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <ScrollAnimations />

    <footer class="site-footer">
      <div class="container">
        <span class="copyright">&copy; 2026 Assah Bismark</span>
      </div>
    </footer>
    <script>
      const searchInput = document.getElementById('archive-search');
      const topPostsBlock = document.getElementById('top-posts-block');
      const yearSections = document.querySelectorAll('.year-section');

      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();

        if (query === '') {
          topPostsBlock.classList.remove('hidden');
          yearSections.forEach(section => {
            section.classList.remove('hidden');
            section.querySelectorAll('li').forEach(li => li.classList.remove('hidden'));
          });
          return;
        }

        topPostsBlock.classList.add('hidden');

        yearSections.forEach(section => {
          const items = section.querySelectorAll('li');
          let visibleCount = 0;
          items.forEach(li => {
            const title = li.getAttribute('data-title') || '';
            if (title.includes(query)) {
              li.classList.remove('hidden');
              visibleCount++;
            } else {
              li.classList.add('hidden');
            }
          });
          section.classList.toggle('hidden', visibleCount === 0);
        });
      });
    </script>
  </body>
</html>
