---
interface MarkdownInstance {
  frontmatter: any;
  url?: string;
}

const socials = [
    { label: "GitHub", url: "https://github.com/AssahBismarkabah" },
    { label: "LinkedIn", url: "https://www.linkedin.com/in/assah-bismark-608a6a251/" },
    { label: "Medium", url: "https://medium.com/@assahbismarkabah" },
    { label: "X", url: "https://x.com/Assah_Bismark" },
    { label: "Instagram", url: "https://www.instagram.com/assah_bismark/" },
    { label: "Email", url: "mailto:abahbismarkassah@gmail.com" },
];

const postImports = import.meta.glob('./docs/blog/*.md', { eager: true }) as Record<string, MarkdownInstance>;
const posts = Object.entries(postImports).map(([path, mod]) => {
  const date = mod.frontmatter?.date || '';
  const year = date ? new Date(date).getUTCFullYear().toString() : 'Undated';
  return {
    url: path.replace('./docs/blog/', '/docs/blog/').replace('.md', ''),
    title: mod.frontmatter?.title || path.split('/').pop()?.replace('.md', '') || '',
    date,
    year,
  };
});
posts.sort((a, b) => (b.date || '').localeCompare(a.date || ''));

// Group by year
const years: Record<string, typeof posts> = {};
posts.forEach(post => {
  if (!years[post.year]) years[post.year] = [];
  years[post.year].push(post);
});
const sortedYears = Object.keys(years).sort((a, b) => b.localeCompare(a));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Archive | Assah Bismark</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro.ttf") format("truetype");
        font-weight: 400;
        font-style: normal;
      }
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro-Display-Bold.otf") format("opentype");
        font-weight: 700;
        font-style: normal;
      }
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro-Italic.ttf") format("truetype");
        font-weight: 400;
        font-style: italic;
      }
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro-Text-Regular.otf") format("opentype");
        font-weight: 500;
        font-style: normal;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        font-family: "SF Pro", "SF Pro Display", "SF Pro Text", "San Francisco",
          "Segoe UI", "Helvetica Neue", Arial, "Liberation Sans",
          system-ui, sans-serif;
      }
      body {
        background: #1e1f21;
        color: #ffffff;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        min-height: 100vh;
      }

      .site-header {
        position: absolute;
        width: 100%;
        padding: 43px 0 35px;
        z-index: 10;
      }
      .header-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }
      .brand {
        font-size: 22px;
        font-weight: 700;
        color: #db0042;
        text-decoration: none;
        line-height: 22px;
      }
      .brand:hover { color: #ff1a5e; }
      .header-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        align-items: baseline;
      }
      .nav-link {
        color: #ffffff;
        text-decoration: none;
        font-size: 17px;
        font-weight: 500;
        line-height: 22px;
        text-transform: capitalize;
        transition: color 0.2s ease;
      }
      .nav-link:hover { color: #b2b2b2; }

      /* Archive section — padding: 165px 0 100px */
      .archive-section {
        padding: 165px 0 100px;
      }
      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
      }

      /* Page title — 32px, 700, margin-bottom: 23px */
      .archive-title {
        font-size: 32px;
        font-weight: 700;
        color: #ffffff;
        line-height: 45px;
        margin: 0 0 23px;
      }

      /* Search block — margin-bottom: 50px */
      .search-block {
        margin: 0 0 50px;
        position: relative;
      }
      .search-form {
        display: flex;
        position: relative;
        width: 100%;
        height: 31px;
      }
      .search-icon {
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 13px;
        height: 13px;
        opacity: 0.7;
        pointer-events: none;
      }
      .search-icon svg {
        width: 13px;
        height: 13px;
        fill: #4c4c4c;
      }
      .search-input {
        font-family: inherit;
        font-size: 15px;
        font-weight: 400;
        color: #ffffff;
        background: transparent;
        border: none;
        border-bottom: 1px solid #ffffff;
        border-radius: 0;
        width: 100%;
        height: 31px;
        padding: 0 0 0 21px;
        line-height: 22.5px;
        outline: none;
      }
      .search-input::placeholder {
        color: #999999;
      }

      /* List block — shared margin for top posts and year blocks */
      .list-block {
        margin: 0 0 50px;
      }

      /* Block title — 17px, 700, opacity: 0.4, margin-bottom: 15px */
      .block-title {
        font-size: 17px;
        font-weight: 700;
        color: #ffffff;
        line-height: 30px;
        margin: 0 0 15px;
        opacity: 0.4;
      }

      /* Year heading — same as block-title */
      .year-title {
        font-size: 17px;
        font-weight: 700;
        color: #ffffff;
        line-height: 30px;
        margin: 0 0 15px;
        opacity: 0.4;
      }

      /* Link list — no bullets, no padding */
      .link-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      /* List item — margin-bottom: 5px */
      .link-list li {
        margin: 0 0 5px;
        list-style: none;
      }

      /* Post link — 20px, 700, #fff, line-height: 40px, no underline */
      .post-link {
        font-size: 20px;
        font-weight: 700;
        color: #ffffff;
        line-height: 40px;
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .post-link:hover { color: #b2b2b2; }

      /* Hide items that don't match search */
      .link-list li.hidden { display: none; }
      .list-block.hidden { display: none; }

      .site-footer { border-top: 1px solid #2d2f30; }
      .site-footer .container { padding-top: 2rem; padding-bottom: 2rem; }
      .copyright { color: #4b5563; font-size: 0.875rem; }

      @media (max-width: 960px) {
        .header-inner, .container { padding: 0 30px; }
      }
      @media (max-width: 768px) {
        .site-header { position: relative; padding: 32px 0 24px; }
        .header-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 1rem;
        }
        .header-inner, .container { padding: 0 24px; }
        .archive-section { padding: 40px 0 60px; }
        .archive-title { font-size: 26px; line-height: 36px; }
        .post-link { font-size: 18px; line-height: 36px; }
      }
      @media (max-width: 480px) {
        .header-inner, .container { padding: 0 16px; }
        .header-nav { gap: 0.5rem 0.75rem; }
        .archive-section { padding: 32px 0 40px; }
        .archive-title { font-size: 24px; }
        .post-link { font-size: 17px; line-height: 32px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand">Assah Bismark</a>
        <nav class="header-nav">
          <a href="/blog" class="nav-link">Archive</a>
          <a href="/categories" class="nav-link">Categories</a>
          {socials.map((social) => (
            <a href={social.url} class="nav-link" target="_blank" rel="noopener noreferrer">{social.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <section class="archive-section">
      <div class="container">
        <h1 class="archive-title">Archive</h1>

        <div class="search-block">
          <div class="search-form">
            <div class="search-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"/></svg>
            </div>
            <input type="search" class="search-input" id="archive-search" placeholder="Search..." autocomplete="off" />
          </div>
        </div>

        <div class="list-block" id="top-posts-block">
          <h2 class="block-title">Top Posts</h2>
          <ul class="link-list">
            {posts.slice(0, 5).map((post) => (
              <li>
                <a href={post.url} class="post-link">{post.title}</a>
              </li>
            ))}
          </ul>
        </div>

        {sortedYears.map((year) => (
          <div class="list-block year-section">
            <h2 class="year-title">{year}</h2>
            <ul class="link-list">
              {years[year].map((post) => (
                <li data-title={post.title.toLowerCase()}>
                  <a href={post.url} class="post-link">{post.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <footer class="site-footer">
      <div class="container">
        <span class="copyright">&copy; 2026 Assah Bismark</span>
      </div>
    </footer>
    <script>
      const searchInput = document.getElementById('archive-search');
      const topPostsBlock = document.getElementById('top-posts-block');
      const yearSections = document.querySelectorAll('.year-section');

      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();

        if (query === '') {
          topPostsBlock.classList.remove('hidden');
          yearSections.forEach(section => {
            section.classList.remove('hidden');
            section.querySelectorAll('li').forEach(li => li.classList.remove('hidden'));
          });
          return;
        }

        topPostsBlock.classList.add('hidden');

        yearSections.forEach(section => {
          const items = section.querySelectorAll('li');
          let visibleCount = 0;
          items.forEach(li => {
            const title = li.getAttribute('data-title') || '';
            if (title.includes(query)) {
              li.classList.remove('hidden');
              visibleCount++;
            } else {
              li.classList.add('hidden');
            }
          });
          section.classList.toggle('hidden', visibleCount === 0);
        });
      });
    </script>
  </body>
</html>
