---
interface MarkdownInstance {
  frontmatter: any;
  rawContent: () => string;
  url?: string;
}

const socials = [
    { label: "GitHub", url: "https://github.com/AssahBismarkabah" },
    { label: "LinkedIn", url: "https://www.linkedin.com/in/assah-bismark-608a6a251/" },
    { label: "Medium", url: "https://medium.com/@assahbismarkabah" },
    { label: "X", url: "https://x.com/Assah_Bismark" },
    { label: "Instagram", url: "https://www.instagram.com/assah_bismark/" },
    { label: "Email", url: "mailto:abahbismarkassah@gmail.com" },
];

const categoryMap: Record<string, { label: string; tags: string[] }> = {
  'ai': { label: 'AI', tags: ['ai', 'rag', 'mcp', 'llm'] },
  'rust': { label: 'Rust', tags: ['rust'] },
  'devops': { label: 'DevOps', tags: ['devops', 'gitops', 'ci', 'deployment', 'github-actions', 'serverless', 'aws'] },
  'apis-and-data': { label: 'APIs & Data', tags: ['graphql', 'api', 'jq', 'json', 'sql', 'postgres', 'database'] },
  'web': { label: 'Web', tags: ['javascript', 'web', 'service-workers'] },
  'security': { label: 'Security', tags: ['keycloak', 'security'] },
  'software-engineering': { label: 'Software Engineering', tags: ['software-engineering', 'architecture', 'complexity', 'concurrency', 'performance', 'programming'] },
  'python': { label: 'Python', tags: ['python'] },
  'java': { label: 'Java', tags: ['java'] },
  'tooling': { label: 'Tooling', tags: ['tooling', 'cli'] },
};

export function getStaticPaths() {
  const categories = ['ai', 'rust', 'devops', 'apis-and-data', 'web', 'security', 'software-engineering', 'python', 'java', 'tooling'];
  return categories.map(slug => ({ params: { slug } }));
}

const slug = Astro.params.slug as string;
const category = categoryMap[slug];
if (!category) throw new Error(`Category not found: ${slug}`);

const postImports = import.meta.glob('../docs/blog/*.md', { eager: true }) as Record<string, MarkdownInstance>;
const posts = Object.entries(postImports)
  .map(([path, mod]) => {
    const tags = (mod.frontmatter?.tags || []) as string[];
    let preview = '';
    if (mod.rawContent) {
      const rawText = mod.rawContent();
      const contentWithoutFrontmatter = rawText.replace(/^---[\s\S]*?---\n\n?/, '');
      const cleanText = contentWithoutFrontmatter
        .replace(/#{1,6}\s+/g, '')
        .replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1')
        .replace(/```[\s\S]*?```/g, '')
        .replace(/`[^`]+`/g, '')
        .replace(/\*\*([^\*]+)\*\*/g, '$1')
        .replace(/\*([^\*]+)\*/g, '$1')
        .replace(/\n+/g, ' ')
        .trim();
      preview = cleanText.substring(0, 300) + (cleanText.length > 300 ? '...' : '');
    } else if (mod.frontmatter?.description) {
      preview = mod.frontmatter.description;
    }
    return {
      url: path.replace('../docs/blog/', '/docs/blog/').replace('.md', ''),
      title: mod.frontmatter?.title || '',
      description: mod.frontmatter?.description || '',
      date: mod.frontmatter?.date || '',
      tags,
      preview,
    };
  })
  .filter(p => p.tags.some(t => category.tags.includes(t)))
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

function formatDate(dateString: string): string {
  if (!dateString) return '';
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC'
  });
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{category.label} | Assah Bismark</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro.ttf") format("truetype");
        font-weight: 400;
        font-style: normal;
      }
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro-Display-Bold.otf") format("opentype");
        font-weight: 700;
        font-style: normal;
      }
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro-Italic.ttf") format("truetype");
        font-weight: 400;
        font-style: italic;
      }
      @font-face {
        font-family: "SF Pro";
        src: url("/fonts/SF-Pro-Text-Regular.otf") format("opentype");
        font-weight: 500;
        font-style: normal;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        font-family: "SF Pro", "SF Pro Display", "SF Pro Text", "San Francisco",
          "Segoe UI", "Helvetica Neue", Arial, "Liberation Sans",
          system-ui, sans-serif;
      }
      body {
        background: #1e1f21;
        color: #ffffff;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        min-height: 100vh;
      }

      .site-header {
        position: absolute;
        width: 100%;
        padding: 43px 0 35px;
        z-index: 10;
      }
      .header-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }
      .brand {
        font-size: 22px;
        font-weight: 700;
        color: #db0042;
        text-decoration: none;
        line-height: 22px;
      }
      .brand:hover { color: #ff1a5e; }
      .header-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        align-items: baseline;
      }
      .nav-link {
        color: #ffffff;
        text-decoration: none;
        font-size: 17px;
        font-weight: 500;
        line-height: 22px;
        text-transform: capitalize;
        transition: color 0.2s ease;
      }
      .nav-link:hover { color: #b2b2b2; }

      .blog-section {
        padding: 177px 0 100px;
      }
      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
      }

      .page-title {
        font-size: 32px;
        font-weight: 700;
        color: #ffffff;
        line-height: 45px;
        margin: 0 0 23px;
      }

      .post-entry {
        padding: 73px 0 0;
      }
      .post-entry:first-child {
        padding-top: 0;
      }

      .post-meta {
        font-size: 18px;
        font-weight: 500;
        color: #ffffff;
        line-height: 28px;
      }

      .post-title-link {
        text-decoration: none;
        color: inherit;
      }
      .post-title {
        font-size: 22px;
        font-weight: 700;
        color: #ffffff;
        line-height: 28px;
        margin-bottom: 13px;
      }
      .post-title-link:hover .post-title {
        color: #e5e7eb;
      }

      .post-description {
        font-size: 18px;
        font-weight: 500;
        color: #ffffff;
        line-height: 29px;
        margin-bottom: 11px;
      }

      .post-preview {
        font-size: 17px;
        font-weight: 500;
        color: #b2b2b2;
        line-height: 30.5px;
      }

      .post-more {
        font-size: 13px;
        font-weight: 500;
        color: #aaaaaa;
        text-decoration: none;
        line-height: 30.5px;
        display: inline;
        transition: color 0.2s ease;
      }
      .post-more:hover { color: #ffffff; }
      .post-more-spacer { display: inline-block; width: 8px; }

      .site-footer { border-top: 1px solid #2d2f30; }
      .site-footer .container { padding-top: 2rem; padding-bottom: 2rem; }
      .copyright { color: #4b5563; font-size: 0.875rem; }

      @media (max-width: 960px) {
        .header-inner, .container { padding: 0 30px; }
      }
      @media (max-width: 768px) {
        .site-header { position: relative; padding: 32px 0 24px; }
        .header-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 1rem;
        }
        .header-inner, .container { padding: 0 24px; }
        .blog-section { padding: 40px 0 60px; }
        .post-entry { padding-top: 48px; }
        .post-title { font-size: 20px; }
        .page-title { font-size: 26px; line-height: 36px; }
      }
      @media (max-width: 480px) {
        .header-inner, .container { padding: 0 16px; }
        .header-nav { gap: 0.5rem 0.75rem; }
        .blog-section { padding: 32px 0 40px; }
        .post-entry { padding-top: 36px; }
        .page-title { font-size: 24px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand">Assah Bismark</a>
        <nav class="header-nav">
          <a href="/blog" class="nav-link">Archive</a>
          <a href="/categories" class="nav-link">Categories</a>
          {socials.map((social) => (
            <a href={social.url} class="nav-link" target="_blank" rel="noopener noreferrer">{social.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <section class="blog-section">
      <div class="container">
        <h1 class="page-title">{category.label}</h1>

        {posts.map((post) => (
          <article class="post-entry">
            <div class="post-meta">{formatDate(post.date)}</div>
            <a href={post.url} class="post-title-link">
              <h2 class="post-title">{post.title}</h2>
            </a>
            {post.description && (
              <div class="post-description">{post.description}</div>
            )}
            <div class="post-preview">
              {post.preview}<span class="post-more-spacer"></span><a href={post.url} class="post-more">More &rsaquo;</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <footer class="site-footer">
      <div class="container">
        <span class="copyright">&copy; 2026 Assah Bismark</span>
      </div>
    </footer>
  </body>
</html>
