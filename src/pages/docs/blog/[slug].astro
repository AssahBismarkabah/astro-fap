---
const socials = [
    { label: "GitHub", url: "https://github.com/AssahBismarkabah" },
    { label: "LinkedIn", url: "https://www.linkedin.com/in/assah-bismark-608a6a251/" },
    { label: "Medium", url: "https://medium.com/@assahbismarkabah" },
    { label: "X", url: "https://x.com/Assah_Bismark" },
    { label: "Instagram", url: "https://www.instagram.com/assah_bismark/" },
    { label: "Email", url: "mailto:abahbismarkassah@gmail.com" },
];

export function getStaticPaths() {
  const allPosts = import.meta.glob('./*.md', { eager: true });
  return Object.keys(allPosts).map((path) => {
    const slug = path.split('/').pop().replace('.md', '');
    return { params: { slug } };
  });
}

const allPosts = import.meta.glob('./*.md', { eager: true });
const slug = Astro.params.slug;
const postEntry = Object.entries(allPosts).find(([path]) =>
  path.endsWith(`/${slug}.md`)
);
if (!postEntry) throw new Error('Post not found');
const post = postEntry[1] as { frontmatter: any; Content: any };

function formatDate(dateString: string): string {
  if (!dateString) return '';
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC'
  });
}
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.frontmatter.title} | Assah Bismark</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @font-face {
        font-family: 'SF Pro';
        src: url('/fonts/SF-Pro.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
      }
      @font-face {
        font-family: 'SF Pro';
        src: url('/fonts/SF-Pro-Display-Bold.otf') format('opentype');
        font-weight: 700;
        font-style: normal;
      }
      @font-face {
        font-family: 'SF Pro';
        src: url('/fonts/SF-Pro-Italic.ttf') format('truetype');
        font-weight: 400;
        font-style: italic;
      }
      @font-face {
        font-family: 'SF Pro';
        src: url('/fonts/SF-Pro-Text-Regular.otf') format('opentype');
        font-weight: 500;
        font-style: normal;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        font-family: 'SF Pro', 'SF Pro Display', 'SF Pro Text', 'San Francisco',
          'Segoe UI', 'Helvetica Neue', Arial, 'Liberation Sans',
          system-ui, sans-serif;
      }
      body {
        background: #1e1f21;
        color: #ffffff;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        min-height: 100vh;
      }

      .site-header {
        position: absolute;
        width: 100%;
        padding: 43px 0 35px;
        z-index: 10;
      }
      .header-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }
      .brand {
        font-size: 22px;
        font-weight: 700;
        color: #db0042;
        text-decoration: none;
        line-height: 22px;
      }
      .brand:hover { color: #ff1a5e; }
      .header-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        align-items: baseline;
      }
      .nav-link {
        color: #ffffff;
        text-decoration: none;
        font-size: 17px;
        font-weight: 500;
        line-height: 22px;
        text-transform: capitalize;
        transition: color 0.2s ease;
      }
      .nav-link:hover { color: #b2b2b2; }

      .post-section { padding: 0 0 100px; }
      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 60px;
      }
      .post-header { padding-top: 140px; }
      .post-meta {
        font-size: 18px;
        font-weight: 500;
        color: #ffffff;
        line-height: 28px;
        margin-bottom: 31px;
      }
      .post-title {
        font-size: 40px;
        font-weight: 700;
        color: #ffffff;
        line-height: 56px;
        margin-bottom: 18px;
      }
      .post-description {
        font-size: 18px;
        font-weight: 500;
        color: #ffffff;
        line-height: 29px;
        padding-bottom: 29px;
        border-bottom: 1px solid #e5e5e5;
      }

      .prose {
        color: #eeeeee;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        margin-top: 31px;
        word-wrap: break-word;
        overflow-wrap: break-word;
      }
      .prose p { margin: 0 0 24px; }
      .prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
        color: #ffffff;
        font-weight: 700;
        margin-top: 2em;
        margin-bottom: 0.7em;
        line-height: 1.3;
      }
      .prose h1 { font-size: 32px; }
      .prose h2 { font-size: 24px; }
      .prose h3 { font-size: 20px; }
      .prose strong { font-weight: 600; color: #ffffff; }
      .prose ul, .prose ol { margin-bottom: 24px; padding-left: 1.5em; }
      .prose li { margin-bottom: 8px; }
      .prose code {
        background: #2a2a2a;
        padding: 0.2em 0.4em;
        border-radius: 0.3em;
        font-size: 0.9em;
      }
      .prose pre {
        background: #18181b;
        padding: 1em;
        border-radius: 0.5em;
        overflow-x: auto;
        margin-bottom: 24px;
      }
      .prose pre code { background: none; padding: 0; }
      .prose blockquote {
        border-left: 4px solid #e5e5e5;
        margin: 0 0 24px;
        padding-left: 1em;
        color: #b2b2b2;
      }
      .prose img { max-width: 100%; border-radius: 0.5em; margin: 24px 0; }
      .prose a {
        color: #60a5fa;
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 0.2s ease;
      }
      .prose a:hover { color: #93c5fd; }
      .prose h1:first-child { display: none; }

      .site-footer { border-top: 1px solid #2d2f30; }
      .site-footer .container { padding-top: 2rem; padding-bottom: 2rem; }
      .copyright { color: #4b5563; font-size: 0.875rem; }

      @media (max-width: 960px) {
        .header-inner, .container { padding: 0 30px; }
      }
      @media (max-width: 768px) {
        .site-header { position: relative; padding: 32px 0 24px; }
        .header-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 1rem;
        }
        .header-inner, .container { padding: 0 24px; }
        .post-header { padding-top: 40px; }
        .post-title { font-size: 28px; line-height: 38px; }
      }
      @media (max-width: 480px) {
        .header-inner, .container { padding: 0 16px; }
        .header-nav { gap: 0.5rem 0.75rem; }
        .post-title { font-size: 24px; line-height: 34px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand">Assah Bismark</a>
        <nav class="header-nav">
          <a href="/blog" class="nav-link">Archive</a>
          <a href="/categories" class="nav-link">Categories</a>
          {socials.map((social) => (
            <a href={social.url} class="nav-link" target="_blank" rel="noopener noreferrer">{social.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <section class="post-section">
      <div class="container">
        <div class="post-header">
          <div class="post-meta">{formatDate(post.frontmatter.date)}</div>
          <h1 class="post-title">{post.frontmatter.title}</h1>
          {post.frontmatter.description && (
            <div class="post-description">{post.frontmatter.description}</div>
          )}
        </div>
        <article class="prose">
          <post.Content />
        </article>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container">
        <span class="copyright">&copy; 2026 Assah Bismark</span>
      </div>
    </footer>
  </body>
</html>
