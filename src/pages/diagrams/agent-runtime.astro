---
import industryV3Url from '../../../diagrams/agent-runtime/src/agent-runtime-industry-v3.svg?url';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agent Runtime Diagram Preview</title>
    <style>
      :root {
        color-scheme: light;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background: #eef2f7;
        color: #0f172a;
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      main {
        width: min(1520px, calc(100vw - 48px));
        margin: 0 auto;
        padding: 32px 0 48px;
      }

      header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 20px;
      }

      h1 {
        margin: 0;
        font-size: 24px;
        line-height: 1.15;
        letter-spacing: 0;
      }

      p {
        margin: 8px 0 0;
        color: #475569;
        font-size: 15px;
      }

      h2 {
        margin: 32px 0 14px;
        font-size: 18px;
        line-height: 1.2;
        letter-spacing: 0;
      }

      a {
        color: #2563eb;
        font-weight: 650;
        text-decoration: none;
      }

      .frame {
        overflow: auto;
        border: 1px solid #cbd5e1;
        border-radius: 18px;
        background: white;
        box-shadow: 0 24px 60px rgb(15 23 42 / 12%);
      }

      img {
        display: block;
        width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <div>
          <h1>Agent Runtime Diagram Preview</h1>
          <p>Source: <code>diagrams/agent-runtime/src/agent-runtime-industry-v3.svg</code></p>
        </div>
        <a href={industryV3Url} target="_blank" rel="noreferrer">Open SVG</a>
      </header>
      <h2>Industry-style v3</h2>
      <section class="frame" aria-label="Industry-style diagram preview">
        <img src={industryV3Url} alt="Industry-style agent runtime separation diagram" />
      </section>
    </main>
  </body>
</html>
